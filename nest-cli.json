{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/curvert/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/curvert/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/curvert",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "curvert": {
      "type": "application",
      "root": "apps/curvert",
      "entryFile": "main",
      "sourceRoot": "apps/curvert/src",
      "compilerOptions": {
        "tsConfigPath": "apps/curvert/tsconfig.app.json"
      }
    },
    "listen": {
      "type": "application",
      "root": "apps/listen",
      "entryFile": "main",
      "sourceRoot": "apps/listen/src",
      "compilerOptions": {
        "tsConfigPath": "apps/listen/tsconfig.app.json"
      }
    }
  }
}